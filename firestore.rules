rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /quotes/{quoteId} {
      allow read, create: if true;
      allow update: if true;
      allow delete: if false;
    }
    match /settings/{docId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
